<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!--
    BepInEx packages (BepInEx.Core, etc.) are NOT on nuget.org — they live on
    BepInEx's own feed. This file adds it so `BepInEx.Core` resolves. After
    adding/editing this, restore again (VS: right-click the solution → "Restore
    NuGet Packages", or run `dotnet restore`).
  -->
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
    <add key="BepInEx" value="https://nuget.bepinex.dev/v3/index.json" />
  </packageSources>
</configuration>
